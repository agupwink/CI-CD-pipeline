# .env.example
#
# This file is a TEMPLATE — copy it to ".env" and fill in real values.
# The actual ".env" file is listed in .gitignore so it is never committed.
#
# Why? Committing secrets (API keys, passwords) to git exposes them to anyone
# who can read the repository, including public GitHub repos. A breach can be
# permanent because git history is hard to fully scrub.

API_KEY=your-secret-api-key-here
